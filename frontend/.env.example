# Optional: override the API base used by the client.
# Default: "/api" (Vite dev proxy forwards to localhost:3000).
# VITE_API_BASE=http://localhost:3000/api

# Optional: change the proxy target used by Vite dev server.
# VITE_API_PROXY=http://localhost:3000

# Required for Supabase Auth, database, and storage.
# Values are available in Supabase Project Settings -> API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
