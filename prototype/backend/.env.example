# ============================================================================
# Gaming Vibe Coding - Stateless AI Backend Configuration
# Copy this file to .env and fill in real values.
# Supabase will own Auth, database, storage, realtime, and persistence.
# ============================================================================

NODE_ENV=development
PORT=3000
HOST=localhost
TRUST_PROXY=false

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# AI mode options:
# real   = OpenRouter-first, local mock only as fallback
# mock   = deterministic local simulator for development/tests
# hybrid = cheap deterministic steps for predictable work, OpenRouter for reasoning-heavy planning
AI_MODE=real
AI_FALLBACK_ENABLED=true
AI_MAX_JSON_OUTPUT_TOKENS=12000
AI_MAX_TEXT_OUTPUT_TOKENS=4000
AI_HARD_MAX_OUTPUT_TOKENS=20000
AI_MAX_INPUT_CHARS=8000
AI_CACHE_TTL_MS=300000
AI_GENERATION_TIMEOUT_MS=90000

OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-5-mini
# Backward-compatible alias used if OPENROUTER_MODEL is unset.
OPENROUTER_DEFAULT_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:5174
OPENROUTER_APP_TITLE=Gaming Vibe Coding

LOG_LEVEL=info

RATE_LIMIT_GENERATION=5
RATE_LIMIT_OPENAI=10
RATE_LIMIT_DEFAULT=30

BODY_LIMIT=1mb
