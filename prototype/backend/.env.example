# ============================================================================
# Gaming Vibe Coding - Backend Configuration
# Copy this file to .env and fill in real values.
# Never commit real API keys or auth secrets.
# ============================================================================

NODE_ENV=development
PORT=3000
HOST=localhost
TRUST_PROXY=false

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# AI provider options: openrouter | openai
AI_PROVIDER=openrouter
AI_FALLBACK_ENABLED=true
AI_MAX_JSON_OUTPUT_TOKENS=12000
AI_MAX_TEXT_OUTPUT_TOKENS=4000
AI_HARD_MAX_OUTPUT_TOKENS=20000

# Recommended for local testing through OpenRouter.
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_DEFAULT_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:5174
OPENROUTER_APP_TITLE=Gaming Vibe Coding

# Optional direct OpenAI mode. Use AI_PROVIDER=openai to enable this path.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-5
GENERIC_OPENAI_ENABLED=false

DATABASE_PATH=./data/gaming-vibe.db

AUTH_TOKEN_SECRET=replace-with-a-random-64-character-secret
AUTH_TOKEN_TTL_SECONDS=604800
DEFAULT_FREE_TOKENS=25
TOKEN_ENFORCEMENT_ENABLED=true
ADMIN_EMAILS=
AUTO_ADMIN_FIRST_USER=false

LOG_LEVEL=info

RATE_LIMIT_GENERATION=5
RATE_LIMIT_OPENAI=10
RATE_LIMIT_DEFAULT=30

BODY_LIMIT=1mb
