{
  "schemaVersion": 1,
  "metadata": {
    "title": "AI Coin Jumper",
    "description": "A compact example showing state, input, behaviors, prefabs, spawners, UI, lights, and tweens.",
    "genre": "platformer"
  },
  "engine": {
    "width": 960,
    "height": 540,
    "enable3D": true,
    "enable2D": true,
    "enablePhysics": true,
    "gravity": { "x": 0, "y": -12, "z": 0 }
  },
  "state": {
    "score": { "type": "number", "initial": 0, "min": 0 },
    "lives": { "type": "number", "initial": 3, "min": 0 }
  },
  "inputBindings": {
    "jump": ["Space", "ArrowUp", "KeyW"],
    "moveLeft": ["ArrowLeft", "KeyA"],
    "moveRight": ["ArrowRight", "KeyD"]
  },
  "prefabs": {
    "coin": {
      "tags": ["coin"],
      "mesh": {
        "shape": "cylinder",
        "radiusTop": 0.35,
        "radiusBottom": 0.35,
        "height": 0.08,
        "color": "#facc15",
        "metalness": 0.2,
        "roughness": 0.4
      },
      "rigidBody": {
        "type": "static",
        "collider": { "shape": "ball", "radius": 0.35 },
        "colliderOptions": { "sensor": true }
      }
    }
  },
  "behaviors": [
    {
      "id": "jump",
      "trigger": { "type": "inputPressed", "input": "jump" },
      "actions": [{ "type": "applyImpulse", "target": "player", "value": { "x": 0, "y": 7, "z": 0 } }]
    },
    {
      "id": "collect-coin",
      "trigger": { "type": "collision", "entityTag": "player", "withTag": "coin" },
      "actions": [
        { "type": "incrementState", "stateKey": "score", "amount": 1 },
        { "type": "destroyEntity", "target": "collisionOther" }
      ]
    },
    {
      "id": "win-at-five",
      "trigger": { "type": "stateChange", "stateKey": "score" },
      "conditions": [{ "stateKey": "score", "gte": 5 }],
      "actions": [{ "type": "switchScene", "scene": "win" }]
    }
  ],
  "animations": [
    {
      "id": "player-breathe",
      "target": "player.scale.y",
      "from": 1,
      "to": 1.08,
      "duration": 0.6,
      "loop": true,
      "yoyo": true,
      "easing": "easeInOut"
    }
  ],
  "scenes": [
    {
      "key": "main",
      "background": "#111827",
      "lights": [
        { "type": "ambient", "color": "#ffffff", "intensity": 0.65 },
        { "type": "directional", "color": "#ffffff", "intensity": 0.9, "position": { "x": 4, "y": 8, "z": 5 } }
      ],
      "entities": [
        {
          "key": "player",
          "tags": ["player"],
          "transform": { "position": { "x": 0, "y": 2, "z": 0 } },
          "mesh": { "shape": "box", "size": { "x": 0.8, "y": 1.2, "z": 0.8 }, "color": "#38bdf8" },
          "rigidBody": {
            "type": "dynamic",
            "collider": { "shape": "cuboid", "halfExtents": { "x": 0.4, "y": 0.6, "z": 0.4 } },
            "linearDamping": 0.2,
            "angularDamping": 1
          },
          "cameraTarget": { "lerp": 5, "offset": { "x": 0, "y": 4, "z": 8 } }
        },
        {
          "key": "ground",
          "tags": ["ground"],
          "transform": { "position": { "x": 0, "y": -0.25, "z": 0 } },
          "mesh": { "shape": "box", "size": { "x": 12, "y": 0.5, "z": 4 }, "color": "#4a7c59" },
          "rigidBody": {
            "type": "static",
            "collider": { "shape": "cuboid", "halfExtents": { "x": 6, "y": 0.25, "z": 2 } }
          }
        }
      ],
      "spawners": [
        {
          "id": "starter-coins",
          "prefab": "coin",
          "positions": [
            { "x": -4, "y": 1.2, "z": 0 },
            { "x": -2, "y": 1.2, "z": 0 },
            { "x": 0, "y": 1.2, "z": 0 },
            { "x": 2, "y": 1.2, "z": 0 },
            { "x": 4, "y": 1.2, "z": 0 }
          ]
        }
      ],
      "ui": [
        { "type": "text", "text": "Score: {score}", "x": 16, "y": 16, "style": { "fontSize": "22px", "color": "#ffffff" } }
      ]
    },
    {
      "key": "win",
      "background": "#052e16",
      "entities": [
        {
          "key": "winner",
          "sprite": {
            "kind": "text",
            "text": "You win!",
            "x": 360,
            "y": 240,
            "style": { "fontSize": "48px", "color": "#ffffff" }
          }
        }
      ]
    }
  ],
  "initialScene": "main"
}
